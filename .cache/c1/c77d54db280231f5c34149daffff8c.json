nfigure,\r\nblockquote,\r\ndl,\r\ndd {\r\n  margin: 0;\r\n}\r\n\r\n/* Remove list styles on ul, ol elements with a list role, which suggests default styling will be removed */\r\nul[role='list'],\r\nol[role='list'] {\r\n  list-style: none;\r\n  // PERSONALY ADDED THESE NEXT LINES\r\n  padding: 0;\r\n  margin: 0;\r\n}\r\n\r\n/* Set core root defaults */\r\nhtml:focus-within {\r\n  scroll-behavior: smooth;\r\n}\r\n\r\n/* Set core body defaults */\r\nbody {\r\n  min-height: 100vh;\r\n  text-rendering: optimizeSpeed;\r\n  line-height: 1.5;\r\n}\r\n\r\n/* A elements that don't have a class get default styles */\r\na:not([class]) {\r\n  text-decoration-skip-ink: auto;\r\n}\r\n\r\n/* Make images easier to work with */\r\nimg,\r\npicture {\r\n  max-width: 100%;\r\n  display: block;\r\n}\r\n\r\n/* Inherit fonts for inputs and buttons */\r\ninput,\r\nbutton,\r\ntextarea,\r\nselect {\r\n  font: inherit;\r\n}\r\n\r\n/* Remove all animations, transitions and smooth scroll for people that prefer not to see them */\r\n@media (prefers-reduced-motion: reduce) {\r\n  html:focus-within {\r\n   scroll-behavior: auto;\r\n  }\r\n  \r\n  *,\r\n  *::before,\r\n  *::after {\r\n    animation-duration: 0.01ms !important;\r\n    animation-iteration-count: 1 !important;\r\n    transition-duration: 0.01ms !important;\r\n    scroll-behavior: auto !important;\r\n  }\r\n}\r\n","scss\\abstracts\\_variables.scss":"// COLORS\r\n// SPACING\r\n// MEDIA QUERIES MIXINS\r\n// EASE FUNCTIONS\r\n\r\n\r\n\r\n/* -------------------------------------------------------------------\r\n--------------   COLORS    --------------\r\n--------------------------------------------------------------------*/\r\n$black: #060606;\r\n$gray: #353C3A;\r\n$midGray: #525F5B;\r\n$lightGray: #F3F0E8;\r\n$white: #FFFFFF;\r\n$turquoise: #21EBD5;\r\n$darkTurquoise: #3FC9C9;\r\n$seaFoam: #FFD0D0;\r\n$darkSeaFoam: #FFB8B8;\r\n$red: #F98383;\r\n$fadedRed: #FFD2B9;\r\n$fadedYellow: #F5E1AC;\r\n\r\n\r\n\r\n\r\n\r\n/* -------------------------------------------------------------------\r\n--------------   SPACING    --------------\r\n--------------------------------------------------------------------*/\r\n$extraSmallSpace: 10px;\r\n$smallSpace: 20px;\r\n$midSpace: 30px;\r\n$largeSpace: 50px;\r\n$extraLargeSpace: 100px;\r\n\r\n// DERIVATIVES\r\n$halfMidSpace: $midSpace/2;\r\n\r\n\r\n\r\n/* -------------------------------------------------------------------\r\n--------------   MEDIA QUERRIES    --------------\r\n--------------------------------------------------------------------*/\r\n\r\n$tablets: 481px;\r\n$laptops: 801px;\r\n$desktops: 1201px;\r\n\r\n$containerConstant: 5%;\r\n\r\n// SOURCE FOR THE FOLLOWING METHODOLOGY\r\n//https://itnext.io/writing-media-queries-with-sass-mixins-3ea591ea3ea4\r\n\r\n@mixin for-phone-only {\r\n    @media (max-width: $tablets-1) {\r\n        @content;\r\n    }\r\n}\r\n\r\n@mixin for-tablets {\r\n    @media (min-width: $tablets) {\r\n        @content;\r\n    }\r\n}\r\n\r\n@mixin for-laptops {\r\n    @media (min-width: $laptops) {\r\n        @content;\r\n    }\r\n}\r\n\r\n@mixin for-desktop-up {\r\n    @media (min-width: $desktops) {\r\n        @content;\r\n    }\r\n}\r\n\r\n\r\n\r\n/* -------------------------------------------------------------------\r\n--------------   EASE FUNCTIONS    --------------\r\n--------------------------------------------------------------------*/\r\n\r\n$slowStartEaseEnd: cubic-bezier(1,.01,.32,1.18);","scss\\utilities\\_shame.scss":"// @use '../base' as *;\r\n@use '../abstracts' as *;\r\n// @use '../components' as *;\r\n@use '../layout' as *;\r\n\r\n\r\n//TEMP\r\nmain {\r\n    background: $turquoise;\r\n    height: 70vh;\r\n}","scss\\components\\_nav.scss":"// @use '../base' as *;\r\n@use '../abstracts' as *;\r\n@use '../layout' as *;\r\n@use '../utilities' as *;\r\n\r\n\r\n// NAV\r\nheader {\r\n    height: $largeSpace;\r\n    position: relative;\r\n\r\n    >* {\r\n        position: fixed;\r\n        left: $containerConstant;\r\n    }\r\n\r\n    div.hamburger-menu--container {\r\n        top: $largeSpace/1.35;\r\n        z-index: 100;\r\n        cursor: pointer;\r\n    }\r\n\r\n    nav {\r\n        top: $largeSpace*1.5;\r\n        z-index: 150;\r\n    }\r\n}\r\n\r\nnav {\r\n    background: $white;\r\n    padding: $largeSpace;\r\n    display: block;\r\n\r\n    &[aria-expanded=\"true\"] {\r\n        display: none;\r\n    }\r\n\r\n    ul {\r\n        text-align: center;\r\n        li {\r\n            a {\r\n                display: block;\r\n                position: relative;\r\n                padding: $midSpace/2;\r\n                color: $gray;\r\n                text-decoration: none;\r\n                font-style: normal;\r\n                font-weight: 700;\r\n                line-height: 135%;\r\n                letter-spacing: 5%;\r\n                transition: color 200ms ease;\r\n                &::before {\r\n                    content: \"\";\r\n                    display: block;\r\n                    position: absolute;\r\n                    z-index: -1;\r\n                    left: 50%;\r\n                    transform: translateX(-50%);\r\n                    transform-origin: bottom;\r\n                    bottom: $extraSmallSpace;\r\n                    height: 3px;\r\n                    width: 100%;\r\n                    background: transparent;\r\n                    pointer-events: none; // MODENIZR MUST INCLUDE THIS\r\n                    transition: transform 350ms $slowStartEaseEnd, background-color 200ms ease-in;\r\n                }\r\n                &:hover {\r\n                    color: $white;\r\n                    transition: color 200ms ease;\r\n                    transition-delay: 300ms;\r\n                   &::before {\r\n                    background: $gray;\r\n                    transform: translateX(-50%) scaleY(10);\r\n                   }\r\n                }\r\n            }\r\n        }\r\n    }\r\n}\r\n\r\n// FOOTER","scss\\base\\_typography.scss":"@use '../components' as *;\r\n@use '../abstracts' as *;\r\n@use '../layout' as *;\r\n@use '../utilities' as *;\r\n\r\n// BASE STYLES (MOBILE)\r\nbody {\r\n    font-family: 'Lato', Arial, Helvetica, sans-serif;\r\n    font-size: 16px;\r\n    color: $gray;\r\n}\r\n\r\nh1 {\r\n    font-size: 1, 75‬rem;\r\n    letter-spacing: 0.01rem;\r\n    line-height: 130%;\r\n    font-weight: 700;\r\n}\r\n\r\nh2 {\r\n    font-size: 1, 5‬rem;\r\n    line-height: 130%;\r\n    letter-spacing: 0.05rem;\r\n    font-weight: 700;\r\n}\r\n\r\nh3 {\r\n    font-size: 1, 125rem;\r\n    line-height: 135%;\r\n    letter-spacing: 0.05rem;\r\n    font-weight: 700;\r\n}\r\n\r\np,\r\na {\r\n    font-size: 1rem;\r\n    line-height: 135%;\r\n    letter-spacing: 0.05rem;\r\n    font-weight: normal;\r\n\r\n    &.small {\r\n        font-size: 0.875rem;\r\n    }\r\n\r\n    &.big {\r\n        font-size: 1, 125rem;\r\n    }\r\n}\r\n\r\na {\r\n    text-decoration: underline;\r\n    color: $gray;\r\n\r\n}\r\n\r\n\r\n// TABLET\r\nh1 {\r\n    font-size: 1, 9rem;\r\n}\r\n\r\n\r\n// DESKTOP/ LAPTOPS\r\nh1 {\r\n    font-size: 2, 18rem;\r\n}"},"lineCount":null}},"error":null,"hash":"67b77101cfdcc9021776f8c73d65790e","cacheData":{"env":{}}}